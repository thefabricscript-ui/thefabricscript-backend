{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TheFabricScriptDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "SecretKey": "REPLACE_WITH_A_STRONG_256BIT_SECRET_KEY_IN_PRODUCTION",
    "Issuer": "TheFabricScript",
    "Audience": "TheFabricScriptClient",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "Google": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID"
  },
  "Razorpay": {
    "KeyId": "YOUR_RAZORPAY_KEY_ID",
    "KeySecret": "YOUR_RAZORPAY_KEY_SECRET",
    "WebhookSecret": "YOUR_RAZORPAY_WEBHOOK_SECRET"
  },
  "Sms": {
    "Provider": "MSG91",
    "ApiKey": "YOUR_MSG91_API_KEY",
    "SenderId": "FABRIC",
    "TemplateId": "YOUR_OTP_TEMPLATE_ID"
  },
  "Email": {
    "Provider": "SMTP",
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "noreply@thefabricscript.com",
    "Password": "YOUR_EMAIL_PASSWORD",
    "FromName": "The Fabric Script"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://thefabricscript.com",
      "https://www.thefabricscript.com"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "5m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/auth/otp/send",
        "Period": "10m",
        "Limit": 5
      }
    ]
  }
}
